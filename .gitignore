# =============================================================================
# TrueNAS Master MCP - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Rust Build Outputs
# -----------------------------------------------------------------------------
/target/
**/*.rs.bk
*.pdb

# Cargo.lock is now tracked by default in binary projects
# Uncomment if you want to ignore it:
# Cargo.lock

# Build artifacts by profile
target/*
!target/.cargo/config

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.netbeans/
*.sublime-*

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.cert

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
*.stderr
*.stdout

# -----------------------------------------------------------------------------
# Testing and Coverage
# -----------------------------------------------------------------------------
coverage/
htmlcov/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.docker/

# -----------------------------------------------------------------------------
# Backup Files
# -----------------------------------------------------------------------------
*~
*.bak
*.backup
*_orig.*
*.rej
*.orig

# -----------------------------------------------------------------------------
# Release and Distribution
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.whl
*.pyc
__pycache__/

# -----------------------------------------------------------------------------
# Pre-commit
# -----------------------------------------------------------------------------
.pre-commit-config.yaml
!.pre-commit-config.yaml

# =============================================================================
# TrueNAS Master MCP - .gitignore
# =============================================================================
# A comprehensive .gitignore for Rust MCP server projects

# -----------------------------------------------------------------------------
# Rust Build Outputs
# -----------------------------------------------------------------------------
# Cargo build directory
.cargo/
/target/
# Per-profile build outputs
target/*
# Backup files created by rustc
**/*.rs.bk
# PDB debug files (Windows)
*.pdb
# LLVM coverage data
*.profraw
*.profdata

# Cargo.lock is tracked by default in binary projects

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.netbeans/
*.sublime-*
.emacs.*
\#*\#
.tags

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.cert
*.secret
*.credentials

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pid
*.seed
*.pid.lock
.linux*

# -----------------------------------------------------------------------------
# Logs and Debug Output
# -----------------------------------------------------------------------------
*.log
logs/
*.stderr
*.stdout
*.out
debug/
debug.log

# -----------------------------------------------------------------------------
# Testing and Coverage
# -----------------------------------------------------------------------------
coverage/
htmlcov/
.nyc_output/
*.lcov
*.cov
tarpaulin-report.html
cargo-test-results/
tracing/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*_orig.*
*.rej
*.orig
*.patch

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
!Dockerfile
docker-compose*.yml
docker-compose*.yaml
.docker/
.container/

# -----------------------------------------------------------------------------
# Release and Distribution
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.whl
*.pyc
__pycache__/
*.wasm

# -----------------------------------------------------------------------------
# Rust Specific
# -----------------------------------------------------------------------------
Cargo.lock
# Uncomment above if you want to ignore Cargo.lock (not recommended for binaries)

# -----------------------------------------------------------------------------
# OpenAPI Generated Files
# -----------------------------------------------------------------------------
*.swagger.json
*.openapi.json

# -----------------------------------------------------------------------------
# Pre-commit
# -----------------------------------------------------------------------------
.pre-commit-config.yaml
!.pre-commit-config.yaml
.pre-commit/

# -----------------------------------------------------------------------------
# MCP Server Files
# -----------------------------------------------------------------------------
!/.1mcprc
!/.dockerignore
*.mcp.json

# -----------------------------------------------------------------------------
# Documentation Build
# -----------------------------------------------------------------------------
docs/.vuepress/dist/
docs/.vuepress/cache/
site/

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.gitattributes
.gitmodules
!.gitmodules

# -----------------------------------------------------------------------------
# Crates.io Publishing
# -----------------------------------------------------------------------------
*.crate

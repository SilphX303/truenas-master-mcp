# TrueNAS Server Configuration
# Either API key OR username/password must be provided

# TrueNAS server URL (required)
TRUENAS_SERVER_URL=https://truenas.local

# Option 1: Use API key for authentication
TRUENAS_API_KEY=your-api-key-here

# Option 2: Use username/password for authentication
# TRUENAS_USERNAME=admin
# TRUENAS_PASSWORD=your-password

# Optional: SSL verification (default: true)
# TRUENAS_VERIFY_SSL=true

# Optional: Request timeout in seconds (default: 30)
# TRUENAS_TIMEOUT=30
